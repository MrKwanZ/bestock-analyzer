# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<YOUR-OPENAI-API-KEY>
# Model to use for report composition, sentiment, and query refinement
OPENAI_MODEL=gpt-4o-mini

# ── Financial data providers ──────────────────────────────────────────────────
# Primary — Alpha Vantage (free key: https://www.alphavantage.co/support/#api-key)
ALPHAVANTAGE_API_KEY=<YOUR-ALPHAVANTAGE-API-KEY>
# Fallback (no key required, set to 1 to enable)
YFINANCE_ENABLED=1

# ── News providers ────────────────────────────────────────────────────────────
# Primary — Brave Search (https://api.search.brave.com)
BRAVE_API_KEY=<YOUR-BRAVE-API-KEY>
# Fallback — SerpAPI (https://serpapi.com)
SERPAPI_API_KEY=<YOUR-SERPAPI-API-KEY>

# ── LangSmith (optional, for tracing and observability) ───────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=<YOUR-LANGSMITH-API-KEY>
LANGSMITH_PROJECT=bestock-agent

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<YOUR-GMAIL-ADDRESS>
# Gmail: Settings → Security → 2-Step Verification → App passwords
SMTP_PASSWORD=<YOUR-GMAIL-APP-PASSWORD>
# Default recipient — can be overridden at runtime via UI or CLI
DEFAULT_EMAIL_RECIPIENT=<YOUR-DEFAULT-RECIPIENT-EMAIL>

# ── Agent defaults ─────────────────────────────────────────────────────────────
# Number of past trading days to analyse (user-adjustable, range: 3–30)
DEFAULT_LOOKBACK_DAYS=5
# Enable advanced analysis (sentiment, volatility, index comparison) by default
ADVANCED_ANALYSIS_ENABLED=false
# Seconds to wait before retrying the same provider after a rate-limit response
RATE_LIMIT_BACKOFF_SECONDS=20
